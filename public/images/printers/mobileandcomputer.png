                  <img src="https://heartland-usa.com/hs-fs/hubfs/Heartland_September2023/Images/Panasonic_logo.jpg?width=251&amp;height=38&amp;name=Panasonic_logo.jpg" alt="Panasonic_logo" loading="" width="251" height="38" srcset="https://heartland-usa.com/hs-fs/hubfs/Heartland_September2023/Images/Panasonic_logo.jpg?width=126&amp;height=19&amp;name=Panasonic_logo.jpg 126w, https://heartland-usa.com/hs-fs/hubfs/Heartland_September2023/Images/Panasonic_logo.jpg?width=251&amp;height=38&amp;name=Panasonic_logo.jpg 251w, https://heartland-usa.com/hs-fs/hubfs/Heartland_September2023/Images/Panasonic_logo.jpg?width=377&amp;height=57&amp;name=Panasonic_logo.jpg 377w, https://heartland-usa.com/hs-fs/hubfs/Heartland_September2023/Images/Panasonic_logo.jpg?width=502&amp;height=76&amp;name=Panasonic_logo.jpg 502w, https://heartland-usa.com/hs-fs/hubfs/Heartland_September2023/Images/Panasonic_logo.jpg?width=628&amp;height=95&amp;name=Panasonic_logo.jpg 628w, https://heartland-usa.com/hs-fs/hubfs/Heartland_September2023/Images/Panasonic_logo.jpg?width=753&amp;height=114&amp;name=Panasonic_logo.jpg 753w" sizes="(max-width: 251px) 100vw, 251px">
                  
